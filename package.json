{
  "name": "guyue-master",
  "productName": "Guyue Master",
  "private": true,
  "version": "1.0.0",
  "description": "macOS 风格的多功能生产力工具",
  "author": "Guyue",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "npx tsc -p electron/tsconfig.json && concurrently \"cross-env NODE_ENV=development npm run dev\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && npx tsc -p electron/tsconfig.json && electron-builder",
    "electron:build:mac": "npm run build && npx tsc -p electron/tsconfig.json && electron-builder --mac",
    "electron:build:dmg": "npm run build && npx tsc -p electron/tsconfig.json && electron-builder --mac dmg",
    "electron:build:win": "npm run build && npx tsc -p electron/tsconfig.json && electron-builder --win",
    "electron:build:linux": "npm run build && npx tsc -p electron/tsconfig.json && electron-builder --linux"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@excalidraw/excalidraw": "^0.18.0",
    "@excalidraw/mermaid-to-excalidraw": "^1.1.2",
    "@google/genai": "^1.30.0",
    "@llamaindex/node-parser": "^2.0.22",
    "@llamaindex/openai": "^0.4.22",
    "@monaco-editor/react": "^4.7.0",
    "@types/dagre": "^0.7.54",
    "@types/howler": "^2.2.12",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@wavesurfer/react": "^1.0.12",
    "@xyflow/react": "^12.10.2",
    "dagre": "^0.8.5",
    "gpt-tokenizer": "^2.9.0",
    "howler": "^2.2.4",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "katex": "^0.16.25",
    "llamaindex": "^0.12.1",
    "lucide-react": "^0.554.0",
    "monaco-editor": "^0.55.1",
    "music-metadata": "^11.12.3",
    "node-pty": "^1.0.0",
    "nodemailer": "^7.0.12",
    "opencode-ai": "1.14.29",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^4.4.168",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.0.0",
    "remark-math": "^6.0.0",
    "wavesurfer.js": "^7.12.5",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-unicode11": "^0.6.0",
    "xterm-addon-web-links": "^0.9.0",
    "xterm-addon-webgl": "^0.16.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^7.0.5",
    "@types/pdf-parse": "^1.1.5",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.3",
    "electron-builder": "^26.0.12",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.guyue.master",
    "productName": "Guyue Master",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "node_modules/opencode-ai/bin",
        "to": "vendor/opencode/bin",
        "filter": [
          ".opencode",
          "opencode"
        ]
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "darkModeSupport": true
    },
    "dmg": {
      "title": "${productName} ${version}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Guyue Master"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "extraMetadata": {
      "main": "dist-electron/main.js"
    }
  }
}
